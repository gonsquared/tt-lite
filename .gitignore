# Dependencies
node_modules/

# Build outputs
dist/
build/

# TypeScript incremental build cache
*.tsbuildinfo

# SQLite databases
*.db
*.sqlite
*.sqlite3

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE / editor
# Use both with and without trailing slash — character devices won't match dir-only patterns
.idea
.idea/
.vscode
.vscode/
*.swp
*.swo

# Tool configs (local/personal, not project-wide)
.mcp.json
.ripgreprc

# Claude Code local settings (CLAUDE.md is tracked at root; .claude/ dir is local-only)
.claude/

# Shell / user dotfiles and git user config (WSL and similar environments may surface these
# in the project root as filesystem artifacts — these are not project files)
.bash_profile
.bashrc
.zshrc
.zprofile
.profile
.zsh_history
.bash_history
.gitconfig
# .gitmodules below is the WSL environment artifact, not a git submodules file.
# This project uses no git submodules. Remove this line if submodules are ever added.
.gitmodules

# Test coverage
coverage/
.nyc_output/

# Cypress artifacts
cypress/videos/
cypress/screenshots/

# Vite cache
.vite/
